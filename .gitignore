# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Packaging
build/
dist/
*.egg-info/
.eggs/

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# Local environment files
.env
.env.*

